WA2DC_TOKEN=TOKEN_GO_HERE
ARESPAWN_URL=http://127.0.0.1:3000
ARESPAWN_EXECUTE_PATH=/execute
ARESPAWN_REQUEST_TIMEOUT_MS=10000
ARESPAWN_WRAPPER_PORT=3000
# Optional: downstream API that wrapper forwards execute requests to
# ARESPAWN_API_BASE_URL=https://api.example.com
# ARESPAWN_API_EXECUTE_PATH=/execute
# ARESPAWN_API_KEY=change-me
# Optional: encrypt SQLite payloads at rest on first DB creation
# WA2DC_DB_PASSPHRASE=change-me
# Optional: notify about prereleases by setting this to unstable (default: stable)
# WA2DC_UPDATE_CHANNEL=stable
# Optional: keep the previous packaged binary to allow rollbacks
# WA2DC_KEEP_OLD_BINARY=1
